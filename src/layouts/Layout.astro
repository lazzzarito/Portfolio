---
import '../styles/global.css'
import favicon from '../assets/favicon.ico';
import aboutImage from '../assets/about.webp';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Portfolio of 1azarito — Web developer specializing in frontend development, UI/UX design, and site fixes. I build fast, clean websites that don't flop." } = Astro.props;

const canonicalURL = Astro.url;
const ogImage = new URL(aboutImage.src, Astro.url).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="1azarito" />
    <meta name="robots" content="index, follow" />

    <link rel="icon" href={favicon} type="image/x-icon" />
    <link rel="shortcut icon" href={favicon} type="image/x-icon" />
    <link rel="canonical" href={canonicalURL} />

    <title>{title}</title>

    <!-- Preconnect for performance -->
    <link rel="preconnect" href="https://github.com" crossorigin />
    <link rel="dns-prefetch" href="https://github.com" />

    <!-- Preload hero image (LCP element) -->
    <link rel="preload" as="image" href={ogImage} fetchpriority="high" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="1azarito | Portfolio" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "1azarito",
      "url": "https://1azarito.dev",
      "image": ogImage,
      "jobTitle": "Web Developer",
      "sameAs": [
        "https://github.com/lazzzarito",
        "https://x.com/1azarito"
      ]
    })} />
  </head>
  <body class="bg-container relative min-h-screen overflow-x-hidden antialiased">
    <div 
      id="matrix-container" 
      class="fixed top-0 left-0 w-full h-full -z-10 pointer-events-none"
      style="mask-image: linear-gradient(to bottom, black 0%, black 80%, transparent 100%); -webkit-mask-image: linear-gradient(to bottom, black 0%, black 80%, transparent 100%);"
    ></div>

    <main class="px-2 sm:px-12 md:px-14 lg:px-28 max-w-360 mx-auto relative z-0 pt-16 md:pt-0">
        <slot />
    </main>

    <button
      id="to-top"
      class="fixed bottom-8 right-4 md:right-8 z-10 p-0 rounded-full bg-background border border-white/10 shadow-2xl transition-all duration-500 translate-y-20 opacity-0 group flex items-center justify-center cursor-pointer"
      aria-label="Back to top"
    >
      <svg class="w-14 h-14 -rotate-90" aria-hidden="true">
        <circle cx="28" cy="28" r="24" fill="none" stroke="currentColor" stroke-width="3" class="text-white/10"></circle>
        <circle
          id="progress-circle"
          cx="28" cy="28" r="24"
          fill="none"
          stroke="currentColor"
          stroke-width="3"
          stroke-dasharray="150.7"
          stroke-dashoffset="150.7"
          stroke-linecap="round"
          class="text-white transition-all duration-100"
        ></circle>
      </svg>
      
      <div class="absolute text-white group-hover:scale-110 transition-transform" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
          <path d="M13.0001 7.82843V20H11.0001V7.82843L5.63614 13.1924L4.22192 11.7782L12.0001 4L19.7783 11.7782L18.3641 13.1924L13.0001 7.82843Z"></path>
        </svg>
      </div>
    </button>

    <script>
      const container = document.getElementById('matrix-container');
      const characters = "{}[]()<>/\\=+*01;";

      function createLetter() {
        if (!container) return;

        const span = document.createElement('span');
        const char = characters[Math.floor(Math.random() * characters.length)];
        const color = "var(--color-textrain)";
        
        const left = Math.random() * 100; 
        const duration = 4 + Math.random() * 8;
        const size = 10 + Math.random() * 10;
        
        span.innerText = char;
        span.className = 'falling-letter';
        span.style.left = `${left}vw`;
        span.style.color = color;
        span.style.fontSize = `${size}px`;
        span.style.animationDuration = `${duration}s`;
        
        span.style.textShadow = `0 0 8px ${color}, 0 0 20px rgba(255,255,255,0.12)`;
        
        container.appendChild(span);

        setTimeout(() => {
          span.remove();
        }, duration * 1000);
      }

      if (window.innerWidth > 768) {
        setInterval(createLetter, 100);
      } else {
        const mobileCount = 25;
        for (let i = 0; i < mobileCount; i++) {
          const span = document.createElement('span');
          const char = characters[Math.floor(Math.random() * characters.length)];
          const color = "var(--color-textrain)";
          const duration = 4 + Math.random() * 8;
          
          span.innerText = char;
          span.className = 'falling-letter';
          span.style.left = `${Math.random() * 100}vw`;
          span.style.color = color;
          span.style.fontSize = `${10 + Math.random() * 10}px`;
          span.style.textShadow = `0 0 8px ${color}, 0 0 20px rgba(255,255,255,0.12)`;
          span.style.animationDuration = `${duration}s`;
          span.style.animationDelay = `-${Math.random() * duration}s`;
          span.style.animationIterationCount = 'infinite';
          
          container.appendChild(span);
        }
      }

      // ** SCROLL TO TOP ** //
      const toTopBtn = document.getElementById('to-top');
      const progressCircle = document.getElementById('progress-circle');
      const circumference = 150.796;
      const arrowIcon = toTopBtn?.querySelector('.absolute');

      function handleScroll() {
        const scrollHeight = document.documentElement.scrollHeight - window.innerHeight;
        const scrollPercentage = window.scrollY / scrollHeight;
        
        const offset = circumference - (scrollPercentage * circumference);
        if (progressCircle) {
          progressCircle.style.strokeDashoffset = offset.toString();
        }

        if (scrollPercentage > 0.5) {
          toTopBtn?.classList.remove('translate-y-20', 'opacity-0');
          toTopBtn?.classList.add('translate-y-0', 'opacity-100');
        } else {
          toTopBtn?.classList.add('translate-y-20', 'opacity-0');
          toTopBtn?.classList.remove('translate-y-0', 'opacity-100');
        }

        if (scrollPercentage > 0.98) {
          arrowIcon?.classList.add('animate-bounce-twice');
        } else {
          arrowIcon?.classList.remove('animate-bounce-twice');
        }
      }

      window.addEventListener('scroll', handleScroll, { passive: true });

      toTopBtn?.addEventListener('click', () => {
      arrowIcon?.classList.add('launching');

      const startPosition = window.scrollY;
      const duration = 750;
      let startTime: number | null = null;
      let requestID: number;

      const stopAnimation = () => {
        cancelAnimationFrame(requestID);
        arrowIcon?.classList.remove('launching');
        window.removeEventListener('wheel', stopAnimation);
        window.removeEventListener('touchmove', stopAnimation);
      };

      function easeOutQuad(t: number, b: number, c: number, d: number) {
        t /= d;
        return -c * t * (t - 2) + b;
      }

      function animation(currentTime: number) {
        if (startTime === null) startTime = currentTime;
        const timeElapsed = currentTime - startTime;
        const run = easeOutQuad(timeElapsed, startPosition, -startPosition, duration);
        
        window.scrollTo(0, run);

        if (timeElapsed < duration) {
          requestID = requestAnimationFrame(animation);
        } else {
          stopAnimation();
        }
      }

      window.addEventListener('wheel', stopAnimation, { once: true });
      window.addEventListener('touchmove', stopAnimation, { once: true });

      requestID = requestAnimationFrame(animation);
    });

    </script>
  </body>
</html>
