---
import { Icon } from "astro-icon/components";
import localData from "../data/home.json";
import { resolveAssetImage } from "../utils/images";
import { Image } from "astro:assets";

interface Social {
  name: string;
  url: string;
  icon: string;
}

interface ProfileData {
  name: string;
  photoUrl: string;
  intro: string;
  socials: Social[];
}

const isApiLive = import.meta.env.PROD;
const BASE_URL = import.meta.env.PUBLIC_API_BASE_URL;

let data: ProfileData;

if (isApiLive && BASE_URL) {
  try {
    const response = await fetch(`${BASE_URL}/home`);
    if (!response.ok) throw new Error("Network response was not ok");
    data = await response.json();
  } catch (error) {
    console.error("API Fetch failed, falling back to mock data", error);
    data = localData as ProfileData;
  }
} else {
  data = localData as ProfileData;
}

const { name, photoUrl, intro, socials } = data;
const profileImage = await resolveAssetImage(photoUrl);
---

<section
  id="home"
  class="flex flex-col items-center justify-center section-container md:pt-30 gap-1 min-h-[80vh] text-center"
>
  <div
    class="relative group mb-2 reveal-content"
    style="animation-delay: 100ms;"
  >
    <div
      class="balloon-float w-20 h-20 md:w-24 md:h-24 rounded-full border-2 border-accent overflow-hidden shadow-[0_0_50px_color-mix(in_srgb,var(--color-accent)_33%,transparent)]"
    >
      <!-- Use Astro Image tag for optimization, fallback to img-->
      {
        profileImage ? (
          <Image
            src={profileImage}
            alt={name}
            class="w-full h-full object-cover scale-110"
            width={192}
            height={192}
            loading="eager"
            decoding="async"
            fetchpriority="high"
            sizes="(max-width: 768px) 80px, 96px"
          />
        ) : (
          <img
            src={photoUrl || "/placeholder.jpeg"}
            alt={name}
            class="w-full h-full object-cover scale-110 fallback-img"
            width={96}
            height={96}
            loading="eager"
            decoding="async"
          />
        )
      }
    </div>
    <div
      class="balloon-float absolute -z-10 top-0 left-0 w-full h-full bg-accent rounded-full blur-[80px] opacity-20"
    >
    </div>
  </div>

  <div class="reveal-content" style="animation-delay: 200ms;">
    <h2 class="font-body font-light text-subtext leading-relaxed text-base">Hello, I'm</h2>
  </div>

  <div
    class="px-6 sm:px-14 md:px-18 lg:px-40 max-w-360 mx-auto relative z-0 reveal-content"
    style="animation-delay: 300ms;"
  >
    <h1
      class="text-5xl md:text-7xl font-heading font-bold text-maintext tracking-tight"
    >
      {name}
    </h1>
    <br />
    <p
      class="text-subtext font-body text-lg leading-relaxed"
      set:html={intro}
    />
  </div>

  <div class="mt-8 mb-4 reveal-content" style="animation-delay: 400ms;">
    <a
      href="#services"
      class="group relative inline-flex items-center justify-center px-10 py-2 border border-accent/20 rounded-full text-maintext font-body transition-all duration-300 hover:border-accent/60 hover:bg-accent/5 hover:shadow-[0_0_20px_color-mix(in_srgb,var(--color-accent)_15%,transparent)] hover:scale-105"
    >
      <div class="flex flex-col items-center justify-center text-center">
        <span
          class="tracking-wide text-sm md:text-base font-medium transition-transform duration-300 md:translate-y-2 md:group-hover:translate-y-0"
        >
          View Services
        </span>

        <span
          class="text-[10px] text-subtext font-light whitespace-nowrap transition-all duration-300 opacity-100 translate-y-0 md:opacity-0 md:translate-y-1 md:group-hover:opacity-100 md:group-hover:translate-y-0"
        >
          What I can do for you?
        </span>
      </div>

      <div
        class="absolute inset-0 rounded-full blur-md bg-accent/10 -z-10 opacity-100 md:opacity-0 md:group-hover:opacity-100 transition-opacity duration-500"
      >
      </div>
    </a>
  </div>

  <div class="flex gap-6 mt-4 reveal-content" style="animation-delay: 500ms;">
    {
      socials
        .filter(
          (social) => social.url && social.url !== "#" && social.url !== "",
        )
        .map((social) => (
          <a
            href={social.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group relative flex flex-col items-center justify-center transition-all duration-300 hover:scale-110"
            aria-label={social.name}
          >
            <Icon
              name={social.icon}
              class="w-8 h-8 text-maintext group-hover:text-accent transition-colors duration-300"
              aria-hidden="true"
            />

            <span class="absolute -bottom-6 scale-0 opacity-0 group-hover:scale-100 group-hover:opacity-100 transition-all duration-300 text-xs text-accent font-body" aria-hidden="true">
              {social.name}
            </span>
          </a>
        ))
    }
  </div>
</section>

<style is:global>
  .reveal-content {
    opacity: 0;
    transform: translateY(20px);
    animation: revealIn 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }

  @keyframes revealIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .balloon-float {
    will-change: transform;
    animation: floating-balloon 8s ease-in-out infinite;
  }

  @keyframes floating-balloon {
    0% {
      transform: translate(0, 0) rotate(0deg);
    }
    33% {
      /* Moves up and slightly right */
      transform: translate(3px, -8px) rotate(1deg);
    }
    66% {
      /* Drifts left and stays elevated */
      transform: translate(-3px, -4px) rotate(-1deg);
    }
    100% {
      /* Returns to start */
      transform: translate(0, 0) rotate(0deg);
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    document
      .querySelectorAll<HTMLImageElement>(".fallback-img")
      .forEach((img) => {
        img.addEventListener("error", () => {
          img.onerror = null;
          img.src = "/placeholder.jpeg";
        });
      });
  });
</script>
