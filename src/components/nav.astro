---
interface NavItem {
  label: string;
  href: string;
  icon: string;
}

const navItems: NavItem[] = [
  {
    label: "Home",
    href: "#home",
    icon: `mdi:home`,
  },
  {
    label: "Services",
    href: "#services",
    icon: `mdi:work`,
  },
  {
    label: "Projects",
    href: "#projects",
    icon: `mdi:computer`,
  },
  {
    label: "Tech",
    href: "#tech",
    icon: `mdi:code-tags`,
  },
  {
    label: "Contact",
    href: "#contact",
    icon: `mdi:message`,
  },
];
---

<!-- ========== MOBILE: HEADER WITH INLINE NAV + GITHUB ========== -->
<header id="mobile-header" class="fixed top-0 left-0 w-full z-50 md:hidden">
  <div class="flex items-center justify-between px-4 py-3 bg-background/70 backdrop-blur-lg border-b border-white/5">
    <!-- Left: brackets icon + section links -->
    <div class="flex items-center gap-2 min-w-0 flex-1">
      <svg class="w-4 h-4 text-accent/80 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="16 18 22 12 16 6"></polyline>
        <polyline points="8 6 2 12 8 18"></polyline>
      </svg>
      <div class="flex items-center gap-0 text-xs sm:text-sm font-heading font-bold tracking-tight overflow-x-auto whitespace-nowrap scrollbar-none">
        {
          navItems.map((item, i) => (
            <>
              {i > 0 && <span class="text-subtext/20 mx-0.5 select-none">/</span>}
              <a
                href={item.href}
                class="mobile-nav-link px-1 py-0.5 text-subtext/60 hover:text-maintext transition-colors duration-200 rounded"
              >
                {item.label}
              </a>
            </>
          ))
        }
      </div>
    </div>

    <!-- Right: GitHub icon -->
    <a
      href="https://github.com/1azarito"
      target="_blank"
      rel="noopener noreferrer"
      class="w-8 h-8 flex items-center justify-center bg-white/5 rounded-full transition-all duration-200 hover:bg-white/10 hover:scale-105 flex-shrink-0 ml-2"
      aria-label="GitHub profile"
    >
      <svg class="w-4 h-4 text-maintext/80" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
      </svg>
    </a>
  </div>
</header>

<!-- ========== DESKTOP: CENTERED NAV ========== -->
<div class="hidden md:flex justify-center w-full">
  <nav
    id="main-nav"
    class="fixed left-1/2 -translate-x-1/2 z-20 border-[1.2px] border-transparent transition-all duration-500 ease-in-out top-6 w-[80%]"
  >
    <div class="container mx-auto flex justify-center items-center p-3">
      <ul class="flex w-full justify-between md:space-x-6 md:justify-center md:gap-12 gap-1">
        {
          navItems.map((item) => (
            <li class="flex-1 md:flex-none">
              <a
                href={item.href}
                class="flex flex-row items-center gap-1 transition-colors text-xs md:text-base relative group text-subtext hover:text-maintext"
              >
                <span class="hidden md:inline-block">{item.label}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </nav>
</div>

<style>
  /* ===== MOBILE NAV LINKS ===== */
  .mobile-nav-link.active {
    color: var(--color-maintext) !important;
  }

  /* Hide scrollbar for the inline nav on mobile */
  .scrollbar-none {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-none::-webkit-scrollbar {
    display: none;
  }

  /* ===== DESKTOP NAV STYLES ===== */
  nav {
    background-color: transparent;
    border-color: transparent;
    backdrop-filter: blur(0px);
    transition:
      background-color 0.4s ease,
      backdrop-filter 0.4s ease,
      border-radius 0.4s ease,
      border-color 0.4s ease,
      width 0.4s ease;
  }

  nav.scrolling {
    background-color: color-mix(
      in srgb,
      var(--color-background),
      transparent 75%
    );
    border-color: color-mix(in srgb, var(--color-accent) 30%, transparent);
    border-radius: 9999px;
    backdrop-filter: blur(10px);
  }

  #main-nav a {
    transition:
      transform 0.3s ease,
      color 0.3s ease,
      font-weight 0.3s ease;
  }

  #main-nav a.active {
    color: var(--color-maintext) !important;
    font-weight: 700;
    transform: scale(1.1);
  }

  #main-nav a.active span {
    text-shadow: 0 0 10px
      color-mix(in srgb, var(--color-maintext) 30%, transparent);
  }

  nav li {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  #main-nav a:not(.active):hover {
    color: var(--color-maintext) !important;
  }

  #main-nav a:not(.active):hover span {
    transform: scale(0.95);
    text-shadow: 0 0 15px color-mix(in srgb, var(--color-maintext) 40%, transparent);
  }
</style>

<script>
  // ===== SMOOTH SCROLL TO SECTION =====
  document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
    anchor.addEventListener("click", function (e) {
      e.preventDefault();
      const targetId = this.getAttribute("href")?.substring(1) || "";
      const targetElement = document.getElementById(targetId);
      if (targetElement) {
        targetElement.scrollIntoView({
          behavior: "smooth",
        });
      }
    });
  });

  // ===== ACTIVE SECTION HIGHLIGHT ON SCROLL =====
  function initActiveSection() {
    const sections = document.querySelectorAll("section[id]");
    const navLinks = document.querySelectorAll(
      "#main-nav a[href^='#'], .mobile-nav-link",
    );

    const siteName = "1azarito";
    const titleMap: Record<string, string> = {
      home: "Portfolio",
      services: "Services",
      projects: "Projects",
      tech: "Tech Stack",
      contact: "Contact",
    };
    const descMap: Record<string, string> = {
      home: "Portfolio of 1azarito — Web developer specializing in frontend development, UI/UX design, and site fixes. I build fast, clean websites.",
      services: "Web development services by 1azarito — custom builds, frontend dev, site fixes, UI/UX design, technical consulting, and no-code solutions.",
      projects: "Featured projects by 1azarito — real client work including brand sites, ecommerce, nonprofit platforms, and experimental web apps.",
      tech: "Tech stack of 1azarito — HTML, CSS, JavaScript, TypeScript, React, Next.js, Astro, Tailwind, WordPress, Node.js, Python, and more.",
      contact: "Contact 1azarito — reach out via GitHub, email, or WhatsApp to discuss your next web project or collaboration.",
    };

    function updateMeta(id: string) {
      if (!id) return;
      const desc = descMap[id];
      if (!desc) return;
      const title = titleMap[id] ? `${siteName} | ${titleMap[id]}` : siteName;

      document.title = title;

      const metaDesc = document.querySelector('meta[name="description"]');
      const ogDesc = document.querySelector('meta[property="og:description"]');
      const twitterDesc = document.querySelector('meta[name="twitter:description"]');
      const ogTitle = document.querySelector('meta[property="og:title"]');
      const twitterTitle = document.querySelector('meta[name="twitter:title"]');

      if (metaDesc) metaDesc.setAttribute("content", desc);
      if (ogDesc) ogDesc.setAttribute("content", desc);
      if (twitterDesc) twitterDesc.setAttribute("content", desc);
      if (ogTitle) ogTitle.setAttribute("content", title);
      if (twitterTitle) twitterTitle.setAttribute("content", title);
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            navLinks.forEach((link) => link.classList.remove("active"));

            const id = entry.target.getAttribute("id");
            if (id) updateMeta(id);

            const desktopLink = document.querySelector(
              `#main-nav a[href="#${id}"]`,
            );
            const mobileLink = document.querySelector(
              `.mobile-nav-link[href="#${id}"]`,
            );

            if (desktopLink) desktopLink.classList.add("active");
            if (mobileLink) mobileLink.classList.add("active");
          }
        });
      },
      {
        rootMargin: "-80px 0px -60% 0px",
      },
    );

    sections.forEach((section) => observer.observe(section));
  }

  // ===== DESKTOP SCROLL MORPHING =====
  const desktopNav = document.getElementById("main-nav");

  function updateNavMorph() {
    const currentScrollY = window.scrollY;

    if (currentScrollY > 0) {
      desktopNav?.classList.add("scrolling");

      const scrollProgress = Math.min(window.scrollY / 1000, 1);
      const easeProgress = 1 - Math.pow(1 - scrollProgress, 4);

      const minWidth = 620;
      const maxWidth = window.innerWidth * 0.8;
      const currentWidth = maxWidth - (maxWidth - minWidth) * easeProgress;

      if (window.innerWidth >= 768) {
        desktopNav?.style.setProperty("width", `${currentWidth}px`);
      }
    } else {
      desktopNav?.classList.remove("scrolling");
    }
  }

  let rafId: number | null = null;
  window.addEventListener(
    "scroll",
    () => {
      if (!rafId) {
        rafId = requestAnimationFrame(() => {
          updateNavMorph();
          rafId = null;
        });
      }
    },
    { passive: true },
  );

  // ===== INIT =====
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initActiveSection);
  } else {
    initActiveSection();
  }
</script>
