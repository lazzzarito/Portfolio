---
import { Icon } from 'astro-icon/components';
const { project } = Astro.props;
import { Image } from 'astro:assets';
import { resolveAssetImage } from '../utils/images';

// Map through the array of image strings from project JSON
const optimizedImages = await Promise.all(
  project.images.map(async (imgName: string) => {
    return await resolveAssetImage(imgName);
  })
);

const validImages = optimizedImages.filter(Boolean);

const isSlider = validImages.length > 1;

// Per-project JSON-LD structured data
const projectSchema = {
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  "name": project.title,
  "description": project.description,
  "url": project.link,
  "keywords": project.tech.join(", "),
  "about": project.category
};
---

<script type="application/ld+json" set:html={JSON.stringify(projectSchema)} />

<div class="project-card group relative bg-accent/5 border border-accent/10 rounded-2xl overflow-hidden hover:border-accent/40 transition-all duration-500" itemscope itemtype="https://schema.org/CreativeWork">
  <div class="aspect-square overflow-hidden relative bg-background/50">
    <div class="absolute inset-0 bg-accent/10 group-hover:bg-transparent transition-colors z-10 pointer-events-none"></div>
    
    <div class={`w-full h-full relative ${isSlider ? 'image-slider' : ''}`}>
      {
        validImages.length > 0 ? (
          validImages.map((imgMetadata, index) => (
            <Image
              src={imgMetadata}
              alt={`${project.title}`}
              class={`absolute inset-0 w-full h-full object-cover transition-all duration-1000 group-hover:scale-110 ${index === 0 ? "opacity-100 z-0" : "opacity-0 z-[-1]"}`}
              width={600}
              height={600}
              loading="lazy"
              decoding="async"
              format="avif"
              sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"
            />
          ))
        ) : (
          /* Fallback box if array is empty or filenames are missing */
          <img
            src="/placeholder.jpeg"
            alt={`${project.title} placeholder`}
            class="absolute inset-0 w-full h-full object-cover transition-all duration-1000 group-hover:scale-110"
            width={600}
            height={600}
            loading="lazy"
            decoding="async"
          />
        )
      }
    </div>
    
    <div class="absolute top-3 right-3 flex gap-2 z-20">
      {project.platforms.map((p: string) => (
        <div class="p-1.5 bg-background backdrop-blur-md rounded-lg border border-accent/10 text-maintext" title={`Available on ${p}`}>
          <Icon name={`mdi:${p}`} class="w-4 h-4" aria-hidden="true" />
        </div>
      ))}
    </div>
  </div>

  <div class="p-6 space-y-4">
    <div class="flex justify-between items-start">
      <div>
        <span class="text-accent text-[10px] uppercase tracking-widest font-bold" itemprop="about">{project.category}</span>
        <h3 class="text-xl font-heading font-bold text-maintext mt-1" itemprop="name">{project.title}</h3>
      </div>        <a href={project.link} target="_blank" rel="noopener noreferrer" class="text-white/50 hover:text-white transition-colors" itemprop="url" title={`View ${project.title} project`}>
          <Icon name="mdi:open-in-new" class="w-6 h-6" />
        </a>
    </div>

    <p class="text-subtext text-sm font-body line-clamp-3" itemprop="description">
      {project.description}
    </p>


  </div>
</div>

<script>
  function initSliders() {
    const sliders = document.querySelectorAll('.image-slider');
    
    sliders.forEach(slider => {
      const images = slider.querySelectorAll('img');
      if (images.length <= 1) return;

      let currentIndex = 0;
      setInterval(() => {
        // Hide current
        images[currentIndex].classList.remove('opacity-100', 'z-0');
        images[currentIndex].classList.add('opacity-0', 'z-[-1]');
        
        // Move to next
        currentIndex = (currentIndex + 1) % images.length;
        
        // Show next
        images[currentIndex].classList.remove('opacity-0', 'z-[-1]');
        images[currentIndex].classList.add('opacity-100', 'z-0');
      }, 3500);
    });
  }

  initSliders();
  document.addEventListener('astro:after-swap', initSliders);
</script>

<style is:global>
  .project-card {
    opacity: 0;
    visibility: hidden;
    transform: translateY(40px);
    transition: 
      opacity 0.8s ease-out, 
      transform 0.8s cubic-bezier(0.16, 1, 0.3, 1),
      visibility 0.8s;
    will-change: transform, opacity;
  }

  .project-card.reveal {
    opacity: 1 !important;
    visibility: visible !important;
    transform: translateY(0) !important;
  }
</style>